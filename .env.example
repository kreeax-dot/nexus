# Copy this file to .env (or .env.local) and customise if needed.
# .env is gitignored; NEVER commit real secrets.
#
# Growth Agent uses a FREE, keyless AI endpoint by default
# (Pollinations — OpenAI-compatible, no signup, no key required).
# If the endpoint is unreachable, the agent silently falls back to a
# data-aware local mock (still supports: task/habit commands,
# sport tracking, score analysis, sleep, priorities).

# Optional — override the default endpoint
# Default: https://text.pollinations.ai/openai
VITE_AI_API_URL=

# Optional — model name used with that endpoint
# Default: openai  (Pollinations aliases this to GPT-4o-mini)
# Other Pollinations options: mistral, llama, claude, gemini, deepseek
VITE_AI_MODEL=
